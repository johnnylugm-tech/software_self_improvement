{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HarnessGateResult",
  "description": "Output contract for software_self_improvement.runner. Written to .sessi-work/gate{n}_result.json. Consumed by harness_bridge._invoke_harness().",
  "type": "object",
  "required": [
    "score",
    "quality_complete",
    "rounds_used",
    "open_critical",
    "open_high",
    "dimensions"
  ],
  "additionalProperties": false,
  "properties": {
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Weighted composite score across all enabled dimensions (0-100)."
    },
    "quality_complete": {
      "type": "boolean",
      "description": "True iff score >= score_gate AND open_critical == 0 AND open_high == 0."
    },
    "rounds_used": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of evaluation rounds executed (1 = first round passed or max=1)."
    },
    "open_critical": {
      "type": "integer",
      "minimum": 0,
      "description": "Count of open issues with severity=critical at end of last round."
    },
    "open_high": {
      "type": "integer",
      "minimum": 0,
      "description": "Count of open issues with severity=high at end of last round."
    },
    "dimensions": {
      "type": "array",
      "minItems": 1,
      "description": "Per-dimension results. Only enabled dimensions are included.",
      "items": {
        "type": "object",
        "required": [
          "name",
          "score",
          "threshold"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "description": "Dimension name matching gate YAML dimensions[].name.",
            "enum": [
              "linting",
              "type_safety",
              "test_coverage",
              "security",
              "secrets_scanning",
              "license_compliance",
              "mutation_testing",
              "architecture",
              "readability",
              "error_handling",
              "documentation",
              "performance"
            ]
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "description": "Reconciled score for this dimension: min(tool_score, llm_score)."
          },
          "threshold": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "description": "Pass threshold from gate YAML dimensions[].threshold. Gate 1 blocks if score < threshold."
          },
          "issues": {
            "type": "array",
            "description": "Open issues found in this dimension (empty if none).",
            "items": {
              "type": "object",
              "required": [
                "severity",
                "file",
                "line",
                "message"
              ],
              "properties": {
                "severity": {
                  "type": "string",
                  "enum": [
                    "critical",
                    "high",
                    "medium",
                    "low"
                  ]
                },
                "file": {
                  "type": "string",
                  "description": "Relative path to affected file."
                },
                "line": {
                  "type": "integer",
                  "minimum": 0
                },
                "message": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}